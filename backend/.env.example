# ============================================
# CONFIGURACIÓN DE DESARROLLO LOCAL - PLATAFORMA MEH
# ============================================
# Este archivo se usa para desarrollo SIN Docker.
# load_dotenv() en auth.py, database.py, y alembic/env.py lo carga automáticamente.
#
# ⚠️ Para DOCKER COMPOSE, usa backend/.env.docker en su lugar
#    (se inyecta vía env_file: en docker-compose.yml, no necesita load_dotenv)
# ============================================

# BASE DE DATOS
# En desarrollo local, PostgreSQL corre en localhost
DATABASE_URL=postgresql://postgres:postgres@localhost/MEH

# PUERTO DEL SERVIDOR UVICORN (opcional — default 8000)
PORT=8000

# AUTENTICACIÓN JWT
SECRET_KEY=mlsa_super_secret_key_2026_thesis_project
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# CONFIGURACIÓN DE CORREOS ELECTRÓNICOS
# ============================================
#
# OPCIÓN 1: Gmail
# 1. Ve a myaccount.google.com
# 2. Si usas 2FA: Ve a "Contraseñas de aplicación"
#    Si no: Habilita "Acceso a aplicaciones menos seguras"
# 3. Copia la contraseña de 16 caracteres (si es app password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password-o-contraseña
EMAIL_FROM_NAME=Plataforma MEH

# ============================================
# URLs DEL FRONTEND (para enlaces en correos)
# ============================================
# En desarrollo local, el frontend corre en Vite (puerto 5173)
FRONTEND_URL=http://localhost:5173
FRONTEND_DASHBOARD=/dashboard
FRONTEND_LEARNING=/learning
FRONTEND_FINANZAS=/finanzas

# ============================================
# OAUTH / AUTENTICACIÓN SOCIAL
# ============================================
# Dejar vacío si no se usa Google OAuth (se desactiva automáticamente)
GOOGLE_CLIENT_ID=

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# - NUNCA commits este archivo si contiene datos sensibles
# - SECRET_KEY debe ser una cadena fuerte en producción
# - SMTP_PASSWORD se almacena en variables de entorno seguras
# - En producción, usa un servicio de secrets (AWS Secrets Manager, etc.)
# - Para Docker Compose, las variables van en backend/.env.docker
#
# Para usar otro proveedor de SMTP, ver app/core/email_config.py