# ==========================================
# .gitignore para Plataforma-MEH (Python + React + Supabase)
# ==========================================

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv
venv/
ENV/
env/
backend/.env
backend/venv/
backend/__pycache__/
.python-version

# --- Node / Frontend ---
node_modules/
frontend/node_modules/
dist/
frontend/dist/
.eslintcache
.stylelintcache
frontend/.env
frontend/.env.local

# --- Base de Datos / SQL ---
*.sqlite3
backend/alembic/__pycache__/

# --- IDEs / Editores ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Archivos Temporales / Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/static/comprobantes/*
!backend/static/comprobantes/.gitkeep
backend/static/uploads/*
!backend/static/uploads/.gitkeep

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
